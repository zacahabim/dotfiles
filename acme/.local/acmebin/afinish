#!/bin/sh
# afinish - wait for a command running in an acme win window to finish
# Usage: afinish
# Waits until the window's event file indicates the command is done.
# Useful in scripts that need to wait for an acme command to complete.

if [ -z "$winid" ]; then
    echo "afinish: must be run from within an acme window" >&2
    exit 1
fi

# Wait by watching for the window's command to complete
# The ctl file shows "clean" when the command is done
while true; do
    ctl=$(9p read acme/$winid/ctl 2>/dev/null)
    if [ $? -ne 0 ]; then
        # Window no longer exists
        break
    fi
    case "$ctl" in
        *clean*) break ;;
    esac
    sleep 0.1
done
