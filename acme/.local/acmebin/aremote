#!/bin/sh
# aremote - execute a command on the remote host if cwd is an sshfs mount
# Usage: aremote command [args...]
# If the current directory is inside an sshfs mount, the command is run
# on the remote host via ssh. Otherwise it runs locally.
# Requires SSH key auth (no interactive password prompts in acme).

if [ $# -eq 0 ]; then
    echo "usage: aremote command [args...]" >&2
    exit 1
fi

cwd=$(/bin/pwd)
mount_info=""
mount_point=""

# Detect sshfs mount
if command -v findmnt >/dev/null 2>&1; then
    # Linux
    mount_info=$(findmnt -T "$cwd" -n -o SOURCE 2>/dev/null)
    mount_point=$(findmnt -T "$cwd" -n -o TARGET 2>/dev/null)
else
    # macOS / BSD - use /sbin/mount to avoid plan9port's mount
    tmpf=/tmp/aremote.$$
    /sbin/mount | grep -E 'macfuse|osxfuse|fuse|sshfs' > "$tmpf"
    while IFS= read -r line; do
        src=$(echo "$line" | awk '{print $1}')
        mp=$(echo "$line" | awk '{print $3}')
        if echo "$cwd/" | grep -q "^${mp}/"; then
            mount_info="$src"
            mount_point="$mp"
            break
        fi
    done < "$tmpf"
    rm -f "$tmpf"
fi

if [ -z "$mount_info" ]; then
    exec "$@"
fi

case "$mount_info" in
    *@*:*)
        userhost="${mount_info%%:*}"
        remote_root="${mount_info#*:}"
        rel="${cwd#"$mount_point"}"
        remote_dir="${remote_root}${rel}"
        # Build a properly quoted command string for ssh
        # Each argument is individually quoted to preserve spaces and special chars
        remote_cmd=""
        for arg in "$@"; do
            if [ -z "$remote_cmd" ]; then
                remote_cmd="'$(echo "$arg" | sed "s/'/'\\\\''/g")'"
            else
                remote_cmd="$remote_cmd '$(echo "$arg" | sed "s/'/'\\\\''/g")'"
            fi
        done
        exec ssh -o ControlMaster=auto \
                 -o ControlPath=/tmp/ssh-acme-%r@%h:%p \
                 -o ControlPersist=600 \
                 "$userhost" "cd '$remote_dir' && $remote_cmd"
        ;;
    *)
        exec "$@"
        ;;
esac
