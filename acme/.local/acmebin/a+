#!/bin/sh
# a+ - open files or directories in acme
# Usage: a+ [file ...]
# If no arguments, opens current directory.

if [ $# -eq 0 ]; then
    set -- .
fi

for f in "$@"; do
    if [ -d "$f" ]; then
        # Directories need trailing slash for acme
        f="${f%/}/"
    fi
    abs=$(cd "$(dirname "$f")" && echo "$(pwd)/$(basename "$f")")
    9p write acme/new/ctl <<EOF
name $abs
get
EOF
done
