#!/bin/sh
# afmt - format the current acme window's file using an appropriate formatter
# Usage: afmt [formatter args...]
# If no formatter given, detects based on file extension.
# The window content is piped through the formatter and replaced.

if [ -z "$winid" ]; then
    echo "afmt: must be run from within an acme window" >&2
    exit 1
fi

# Get the filename from the window tag
name=$(9p read acme/$winid/tag | sed 1q | awk '{print $1}')

if [ $# -gt 0 ]; then
    formatter="$@"
else
    # Auto-detect formatter based on extension
    case "$name" in
        *.go)       formatter="gofmt" ;;
        *.py)       formatter="black -q -" ;;
        *.rs)       formatter="rustfmt" ;;
        *.js|*.ts|*.jsx|*.tsx) formatter="prettier --stdin-filepath $name" ;;
        *.json)     formatter="jq ." ;;
        *.sh)       formatter="shfmt" ;;
        *.c|*.h)    formatter="clang-format" ;;
        *.cpp|*.cc|*.hpp) formatter="clang-format" ;;
        *)
            echo "afmt: no formatter known for $name" >&2
            exit 1
            ;;
    esac
fi

# Read body, format, write back
echo 'comma' | 9p write acme/$winid/addr
body=$(9p read acme/$winid/data)
formatted=$(printf '%s' "$body" | eval $formatter)

if [ $? -eq 0 ] && [ -n "$formatted" ]; then
    echo 'comma' | 9p write acme/$winid/addr
    printf '%s' "$formatted" | 9p write acme/$winid/data
fi
