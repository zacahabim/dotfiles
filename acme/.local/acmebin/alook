#!/bin/sh
# alook - look up the selected word using look(1) or grep in the file
# Usage: alook [pattern]
# If no pattern given, uses the current selection.

if [ -z "$winid" ]; then
    echo "alook: must be run from within an acme window" >&2
    exit 1
fi

if [ $# -gt 0 ]; then
    pattern="$1"
else
    pattern=$(9p read acme/$winid/rdsel)
fi

if [ -z "$pattern" ]; then
    echo "alook: no pattern" >&2
    exit 1
fi

# Try look(1) first for dictionary lookup, fallback to grep in file
if command -v look >/dev/null 2>&1; then
    look "$pattern"
else
    name=$(9p read acme/$winid/tag | sed 1q | awk '{print $1}')
    grep -n "$pattern" "$name"
fi
